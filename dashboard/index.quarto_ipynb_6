      "source": [
        "#| label: curva-impacto\n",
        "\n",
        "edad    = np.linspace(0, 18, 200)\n",
        "retorno = 12 * np.exp(-0.28 * edad)\n",
        "costo   = 1 + edad * 0.3\n",
        "\n",
        "fig5 = go.Figure()\n",
        "\n",
        "fig5.add_vrect(\n",
        "    x0=0, x1=3,\n",
        "    fillcolor=C_ALTO, opacity=0.12,\n",
        "    annotation_text=\"Ventana crítica 0–3 años\",\n",
        "    annotation_position=\"top left\",\n",
        "    annotation_font_size=11,\n",
        ")\n",
        "fig5.add_vrect(\n",
        "    x0=3, x1=6,\n",
        "    fillcolor=C_MEDIO, opacity=0.10,\n",
        "    annotation_text=\"Preescolar\",\n",
        "    annotation_position=\"top left\",\n",
        "    annotation_font_size=10,\n",
        ")\n",
        "fig5.add_trace(go.Scatter(\n",
        "    x=edad, y=retorno,\n",
        "    fill=\"tozeroy\",\n",
