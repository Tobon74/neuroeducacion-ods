        "#| label: radar-comparativo\n",
        "\n",
        "estados_radar = [\"Chiapas\", \"Guerrero\", \"Oaxaca\", \"Ciudad de México\", \"Nuevo León\"]\n",
        "dims = [\n",
        "    \"rezago_educativo_pct\",\n",
        "    \"desnutricion_cronica_pct\",\n",
        "    \"pobreza_extrema_pct\",\n",
        "    \"pobreza_total_pct\",\n",
        "    \"pct_pobl_vulnerable\",\n",
        "]\n",
        "dims_labels = [\n",
        "    \"Rezago educativo\",\n",
        "    \"Desnutrición infantil\",\n",
        "    \"Pobreza extrema\",\n",
        "    \"Pobreza total\",\n",
        "    \"Pobl. 0–4 años\",\n",
        "]\n",
        "colores = [C_CRITICO, C_ALTO, \"#F4A261\", C_BAJO, \"#457B9D\"]\n",
        "\n",
        "fig3 = go.Figure()\n",
        "for i, estado in enumerate(estados_radar):\n",
        "    row = df[df[\"estado\"] == estado]\n",
        "    if row.empty:\n",
        "        continue\n",
        "    vals = [float(row[d].iloc[0]) for d in dims]\n",
        "    vals_norm = [(v / max(df[d].max(), 1)) * 100 for v, d in zip(vals, dims)]\n",
        "    vals_norm.append(vals_norm[0])\n",
        "    fig3.add_trace(go.Scatterpolar(\n",
        "        r=vals_norm,\n",
        "        theta=dims_labels + [dims_labels[0]],\n",
        "        fill=\"toself\",\n",
        "        fillcolor=colores[i],\n",
        "        opacity=0.22,\n",
        "        line=dict(color=colores[i], width=2),\n",
        "        name=f\"{estado} (IVN={float(row['IVN'].iloc[0]):.0f})\",\n",
        "    ))\n",
        "\n",
        "fig3.update_layout(\n",
        "    polar=dict(\n",
        "        radialaxis=dict(visible=True, range=[0, 100], tickfont_size=9, gridcolor=\"#ddd\"),\n",
        "        bgcolor=C_FONDO,\n",
        "    ),\n",
        "    title=\"Perfil comparativo: estados críticos vs bajo riesgo\",\n",
        "    paper_bgcolor=\"white\",\n",
        "    font_family=\"Georgia, serif\",\n",
        "    font_color=\"#1D3557\",\n",
        "    title_font_size=16,\n",
        "    height=500,\n",
        "    showlegend=True,\n",
        "    legend=dict(orientation=\"h\", y=-0.18),\n",
        ")\n",
        "fig3.show()"
      ],
